["Treasure Room"] = {Pos = Vector3.new(-3561.297, -279.074, -1606.289), Look = Vector3.new(-0.782, -0.000, -0.623)},

-- // CONFIGURATION //
local TARGET_GUI = "Prompt"
local TARGET_BUTTON = "Yes"
local CLICKS_PER_SECOND = 1

-- // SERVICES //
local Players = game:GetService("Players")
