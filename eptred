        end
    end
end)

-- // ================= AUTO-ACCEPT TRADE FUNCTION ================= //
local function getButtonRect(button)
    if not (button and button.Visible and button.AbsoluteSize.Magnitude > 0) then return nil end
    
    local absPos = button.AbsolutePosition
    local absSize = button.AbsoluteSize
    local guiInset = GuiService:GetGuiInset()
    
    return {
        X = absPos.X,
        Y = absPos.Y + guiInset.Y,
        W = absSize.X,
        H = absSize.Y
    }
end

local function clickXY(x, y)
    -- Simulasi input mouse yang lebih realistis
    VirtualInputManager:SendMouseMoveEvent(x, y, game)
    task.wait(0.05)
    
    -- Mouse down
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.05)
    
    -- Mouse up
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    task.wait(0.05)
    
    -- Gerakkan mouse sedikit untuk natural
    VirtualInputManager:SendMouseMoveEvent(x + math.random(-2,2), y + math.random(-2,2), game)
end

-- // MAIN LOOP UNTUK AUTO-ACCEPT //
task.spawn(function()
    print("🔄 Auto-Accept scanner started...")
    
    while true do
        pcall(function()
            local prompt = PlayerGui:FindFirstChild(TARGET_GUI)
            
            if prompt and prompt.Enabled then
                for _, obj in ipairs(prompt:GetDescendants()) do
                    if obj.Name == TARGET_BUTTON and obj:IsA("ImageButton") and obj.Visible then
                        
                        -- Validasi Teks untuk memastikan ini trade prompt (bukan sell)
                        local parentFrame = obj.Parent and obj.Parent.Parent
                        local label = parentFrame and parentFrame:FindFirstChild("Label")
                        
                        if label then
                            local text = label.Text:lower()
                            if text:find("from") or text:find("give") or text:find("trade") then
                                local rect = getButtonRect(obj)
                                if rect then
                                    local centerX = rect.X + (rect.W / 2)
                                    local centerY = rect.Y + (rect.H / 2)
                                    
                                    -- Random offset kecil agar tidak selalu klik di titik sama
                                    local clickX = centerX + math.random(-3, 3)
                                    local clickY = centerY + math.random(-3, 3)
                                    
                                    warn("💰 [TRADE DETECTED] Clicking Yes...")
                                    clickXY(clickX, clickY)
                                    
                                    -- Jeda antar klik
                                    task.wait(1 / CLICKS_PER_SECOND)
                                end
                            end
                        end
                    end
                end
            end
        end)
        
        -- Scan interval
        task.wait(0.3)
    end
end)

