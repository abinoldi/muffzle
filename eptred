-- // ================= SAFE TELEPORT FUNCTION ================= //
local function safeTeleportToTreasureRoom()
    local targetPos = Vector3.new(-3561.297, -279.074, -1606.289)
    local targetLook = Vector3.new(-0.782, -0.000, -0.623)
    
    -- Tunggu hingga karakter siap
    local char = LocalPlayer.Character
    if not char then
        char = LocalPlayer.CharacterAdded:Wait()
    end
    
    local hrp = char:WaitForChild("HumanoidRootPart")
    local humanoid = char:WaitForChild("Humanoid")
    
    -- Simpan state awal
    local originalWalkSpeed = humanoid.WalkSpeed
    local originalJumpPower = humanoid.JumpPower
    
    -- // TELEPORT METHOD: ANTI-DETECTION COMBO //
    
    -- Step 1: Nonaktifkan kontrol player sementara
    humanoid:ChangeState(Enum.HumanoidStateType.Physics)
    humanoid.WalkSpeed = 0
    humanoid.JumpPower = 0
    
    -- Step 2: Pindahkan ke koordinat aman (langit) untuk "menyembunyikan" teleport
    hrp.CFrame = CFrame.new(0, 1000, 0)
    task.wait(0.2)
    
    -- Step 3: Buat efek visual tipu-tipu (optional, kalau game punya efek)
    -- Contoh: spawn part kecil untuk mengalihkan perhatian anti-cheat
    local decoyPart = Instance.new("Part")
    decoyPart.Size = Vector3.new(1, 1, 1)
    decoyPart.Transparency = 1
    decoyPart.CFrame = hrp.CFrame
    decoyPart.Parent = workspace
    
    -- Step 4: Teleport bertahap (3 langkah cepat) ke target
    local steps = 5
    for i = 1, steps do
        local alpha = i / steps
        local intermediatePos = Vector3.new(0, 1000, 0):Lerp(targetPos, alpha)
        hrp.CFrame = CFrame.new(intermediatePos)
        task.wait(0.03) -- Delay kecil antar step
    end
    
    -- Step 5: Set final position with look direction
    local finalCFrame = CFrame.lookAt(targetPos, targetPos + targetLook)
    hrp.CFrame = finalCFrame
    
    -- Step 6: Bersihkan decoy
    decoyPart:Destroy()
    
    -- Step 7: Kembalikan kontrol player
    task.wait(0.1)
    humanoid:ChangeState(Enum.HumanoidStateType.Running)
    humanoid.WalkSpeed = originalWalkSpeed
    humanoid.JumpPower = originalJumpPower
    
    -- Step 8: Reset kamera (optional)
    task.wait(0.1)
    if workspace.CurrentCamera then
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        workspace.CurrentCamera.CameraSubject = humanoid
        workspace.CurrentCamera.CameraType = Enum.CameraType.Track
    end
    
    print("✅ [SAFE TELEPORT] Successfully arrived at Treasure Room!")
    
    -- Notifikasi sukses
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "✅ Safe Teleport Success!";
        Text = "Arrived at Treasure Room (Undetected Method)";
        Duration = 3;
    })
end

-- Eksekusi teleport sekali dengan delay untuk keamanan ekstra
task.spawn(function()
    -- Tunggu game fully loaded
    task.wait(2)
    
    -- Pastin player sudah spawn
    if not LocalPlayer.Character then
        LocalPlayer.CharacterAdded:Wait()
    end
    
    -- Eksekusi safe teleport
    local success, err = pcall(safeTeleportToTreasureRoom)
