async function isUserInGame(pkg, cookie, userId) {
  const now = Date.now();
  const lastLaunch = launchTimers[pkg] || 0;
  const timeSinceLaunch = now - lastLaunch;
  
  if (lastLaunch > 0 && timeSinceLaunch < PRESENCE_CHECK_DELAY) {
    return { isInGame: true, status: "loading", timeRemaining: PRESENCE_CHECK_DELAY - timeSinceLaunch };
  }
  
  if (cookie && userId) {
    const robloxPresence = await checkRobloxPresence(cookie, userId, pkg);
    if (robloxPresence.isInGame) {
      return { isInGame: true, status: "in-game", source: "roblox-api" };
    }
    
    if (robloxPresence.presenceType === 0) {
      return { isInGame: false, status: "offline", source: "roblox-api" };
    }
  }
  
  try {
    const { stdout: foregroundApp } = await execAsync(`su -c "dumpsys window windows | grep -E 'mCurrentFocus|mFocusedApp' | head -1"`);
    if (foregroundApp.includes(pkg) || foregroundApp.includes("Roblox")) {
      return { isInGame: true, status: "in-game", source: "foreground" };
    }
  } catch (e) {}
  
  try {
    const { stdout: visibleActivity } = await execAsync(`su -c "dumpsys activity activities | grep -B 5 -A 5 '${pkg}' | grep -E 'mVisible=true|ResumedActivity'"`);
    if (visibleActivity) {
      return { isInGame: true, status: "in-game", source: "activity" };
    }
  } catch (e) {}
  
  return { isInGame: false, status: "unknown" };
}

async function isAppHealthy(pkg, cookie, userId) {
  const processRunning = await isAppRunningAsync(pkg);
  if (!processRunning) {
    return { healthy: false, reason: "Process Not Running", ram: 0, priority: "critical" };
  }
  
  const ramStr = await getAppRamAsync(pkg);
  const ramValue = parseFloat(ramStr) || 0;
  if (ramValue < MIN_RAM_THRESHOLD && ramValue > 0) {
    return { 
      healthy: false, 
      reason: `Low RAM (${ramValue}MB) - Crash`, 
      ram: ramValue,
      priority: "high"
    };
  }
  
  const presenceResult = await isUserInGame(pkg, cookie, userId);
  
  if (presenceResult.status === "loading") {
    return { 
      healthy: true, 
      reason: `Loading (${Math.round(presenceResult.timeRemaining/1000)}s left)`, 
      ram: ramValue,
      priority: "normal",
      loading: true
    };
  }
  
  if (!presenceResult.isInGame) {
    return { 
      healthy: false, 
      reason: "User Not In Game", 
      ram: ramValue,
      priority: "high"
    };
  }
  
  return { 
    healthy: true, 
    reason: "Healthy", 
    ram: ramValue,
    priority: "normal"
  };
}

