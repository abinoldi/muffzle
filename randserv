async function getCsrfToken(cookie) {
  try {
    const res = await axios.post('https://auth.roblox.com/v2/logout', {}, {
      headers: { 
        Cookie: `.ROBLOSECURITY=${cookie}`,
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
      },
      validateStatus: () => true
    });
    return res.headers['x-csrf-token'] || null;
  } catch (error) {
    if (error.response && error.response.headers['x-csrf-token']) {
      return error.response.headers['x-csrf-token'];
    }
  }
  return null;
}

async function checkCookieValidity(cookie) {
    const userAgent = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/116.0.0.0 Safari/537.36";
    const csrf = await getCsrfToken(cookie);
    
    if (!csrf) return "INVALID";

    try {
        const payload = { placeId: parseInt(PLACE_ID), isTeleport: false };
        const res = await axios.post(URL_JOIN, payload, {
            headers: {
                "Cookie": `.ROBLOSECURITY=${cookie}`,
                "User-Agent": userAgent,
                "Content-Type": "application/json",
                "Referer": `https://www.roblox.com/games/${PLACE_ID}/`,
                "Origin": "https://www.roblox.com",
                "X-Csrf-Token": csrf
            },
            validateStatus: () => true
        });

        if (res.status === 200) return "CLEAN";

        const challengeType = (res.headers["rblx-challenge-type"] || res.headers["x-roblox-challenge-type"] || "").toLowerCase();
        if (challengeType.includes("proofofwork") || challengeType.includes("proof-of-work")) return "POW";
        if (challengeType.includes("proofofspace") || challengeType.includes("proof-of-space")) return "POS";
        if (challengeType === "captcha") return "CAPTCHA";

        const metaB64 = res.headers["rblx-challenge-metadata"];
        if (metaB64) {
            try {
                const decodedStr = Buffer.from(metaB64, 'base64').toString('utf-8');
                const decodedMeta = JSON.parse(decodedStr);
                const actionType = (decodedMeta.actionType || "").toLowerCase();
                
                if (actionType.includes("proofofwork") || actionType.includes("pow")) return "POW";
                if (actionType.includes("proofofspace") || actionType.includes("pos")) return "POS";
                return "CAPTCHA"; 
            } catch (err) {}
        }

        if (res.status === 403) {
            const data = res.data;
            if (data && data.errors && data.errors.length > 0) {
                const msg = (data.errors[0].message || "").toLowerCase();
                if (msg.includes("captcha")) return "CAPTCHA";
                if (msg.includes("proof of work") || msg.includes("pow")) return "POW";
                if (msg.includes("proof of space") || msg.includes("pos")) return "POS";
            }
            return "INVALID";
        }
        return "ERROR";
    } catch (e) {
        return "ERROR";
    }
}

async function runSolver(fullCookie, accPkg) {
    try {
        accountStates[accPkg].serverStatus = "🔍 Checking Type...";
        const challengeType = await checkCookieValidity(fullCookie);

        if (challengeType === "CLEAN") {
            accountStates[accPkg].serverStatus = "✅ Clean (No Captcha)";
            return true;
        } else if (challengeType === "INVALID" || challengeType === "ERROR") {
            accountStates[accPkg].serverStatus = `❌ Cookie ${challengeType}`;
            return false;
        }

        accountStates[accPkg].serverStatus = `⏳ Solving ${challengeType}...`;

        let solveUrl = challengeType === "CAPTCHA" ? SOLVER_CAPTCHA_URL : SOLVER_POW_URL;

        const res = await axios.post(solveUrl, 
            { cookie: fullCookie, placeId: parseInt(PLACE_ID) },
            {
                headers: {
                    "Content-Type": "application/json",
                    "X-API-Key": WINTERCODE_API_KEY
                },
                timeout: 60000 
            }
        );

        if (res.data && res.data.success) {
            accountStates[accPkg].serverStatus = `✅ ${challengeType} Solved!`;
            return true;
        } else {
            accountStates[accPkg].serverStatus = `❌ ${challengeType} Failed`;
            return false;
        }
    } catch (error) {
      if (error.response) {
          accountStates[accPkg].serverStatus = `❌ API Error (${error.response.status})`;
      } else if (error.request) {
          accountStates[accPkg].serverStatus = "⚠️ API Timeout/No Response";
      } else {
          accountStates[accPkg].serverStatus = "❌ Setup Error";
      }
      return false;
  }
}

async function checkRobloxPresence(cookie, userId, pkg) {
  try {
    if (!csrfTokens[pkg]) {
      csrfTokens[pkg] = await getCsrfToken(cookie);
    }

    const presenceResponse = await axios.post('https://presence.roblox.com/v1/presence/users', 
      { userIds: [userId] },
      {
        headers: {
          'Cookie': `.ROBLOSECURITY=${cookie}`,
          'x-csrf-token': csrfTokens[pkg] || '',
          'Content-Type': 'application/json',
          'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
        }
      }
    );

    const presence = presenceResponse.data.userPresences[0];
    return {
      isInGame: presence.userPresenceType === 2,
      presenceType: presence.userPresenceType,
      lastLocation: presence.lastLocation,
      placeId: presence.placeId,
      gameId: presence.gameId
    };
  } catch (error) {
    if (error.response && error.response.status === 403) {
      csrfTokens[pkg] = await getCsrfToken(cookie);
      try {
        const retryResponse = await axios.post('https://presence.roblox.com/v1/presence/users', 
          { userIds: [userId] },
          {
            headers: {
              'Cookie': `.ROBLOSECURITY=${cookie}`,
              'x-csrf-token': csrfTokens[pkg] || '',
              'Content-Type': 'application/json'
            }
          }
        );
        const presence = retryResponse.data.userPresences[0];
        return {
          isInGame: presence.userPresenceType === 2,
          presenceType: presence.userPresenceType
        };
      } catch (retryError) {}
    }
    return { isInGame: false, presenceType: 0 };
  }
}

