async function ensureAppPreLaunched(acc, codeDisplay) {
  let isPreLaunchSuccess = false;
  let attempt = 0;

  while (!isPreLaunchSuccess && attempt < MAX_LOOP_ATTEMPTS) {
    attempt++;
    accountStates[acc.pkg].serverStatus = `Pre-launching 🐒 (Try ${attempt}/${MAX_LOOP_ATTEMPTS})`;
    renderDashboard(codeDisplay, `🐒 Pre-launch ${acc.pkg} dengan Monkey...`);
    
    await execAsync(`su -c "monkey -p ${acc.pkg} -c android.intent.category.LAUNCHER 1"`).catch(()=>{});
    
    let waitTime = 30; 
    let crashedDuringPreLaunch = false;

    for (let w = 1; w <= waitTime; w++) {
       renderDashboard(codeDisplay, `⏳ Menunggu app ${acc.username} terbuka... (${w}/${waitTime}s)`);
       await sleep(1000);

       if (w % 5 === 0) {
         const isRunning = await isAppRunningAsync(acc.pkg);
         const ramStr = await getAppRamAsync(acc.pkg);
         const ramVal = parseFloat(ramStr) || 0;
         
         if (!isRunning || (ramVal > 0 && ramVal < MIN_RAM_THRESHOLD)) {
            renderDashboard(codeDisplay, `⚠️ ${acc.username} Crash saat Pre-launch (RAM: ${ramVal}MB)! Mengulangi...`);
            crashedDuringPreLaunch = true;
            break; 
         }
       }
    }

    if (!crashedDuringPreLaunch) {
        isPreLaunchSuccess = true;
        accountStates[acc.pkg].serverStatus = "Standby ✅";
        renderDashboard(codeDisplay, `✅ App ${acc.username} sukses standby di background!`);
        await sleep(1500);
    } else {
        await stopPackageAsync(acc.pkg);
        await releaseMemoryAsync();
        await sleep(2000);
    }
  }
  
  if (!isPreLaunchSuccess) {
      accountStates[acc.pkg].serverStatus = "❌ Failed Pre-launch";
  }
  return isPreLaunchSuccess;
}

