function getRobloxCookie(packageName) {
  try {
    const cookiesPath = `/data/data/${packageName}/app_webview/Default/Cookies`;
    const tempPath = `/sdcard/temp_cookie_${packageName}_${Date.now()}.db`;
    execSync(`cp "${cookiesPath}" "${tempPath}"`);
    const sqliteCmd = fs.existsSync(SQLITE_PATH) ? SQLITE_PATH : "sqlite3";
    const query = `${sqliteCmd} "${tempPath}" "SELECT value FROM cookies WHERE name = '.ROBLOSECURITY' LIMIT 1"`;
    let cookie = execSync(query).toString().trim();
    execSync(`rm "${tempPath}"`);
    if (cookie && !cookie.startsWith("_")) cookie = "_" + cookie;
    return cookie ? cookie : null; // Kembalikan cookie tanpa .ROBLOSECURITY=
  } catch { return null; }
}

async function getUserInfo(cookie) {
  if (!cookie) return { id: null, name: "No Cookie" };
  try {
    const res = await axios.get("https://users.roblox.com/v1/users/authenticated", {
      headers: { 
        Cookie: `.ROBLOSECURITY=${cookie}`, 
        "User-Agent": "Mozilla/5.0 (Android 10; Mobile)" 
      }
    });
    return { id: res.data.id, name: res.data.name };
  } catch { 
    return { id: null, name: "Expired" };
  }
}

// --- FUNCTION TO GET CSRF TOKEN FROM ROBLOX ---
async function getCsrfToken(cookie) {
  try {
    await axios.post('https://auth.roblox.com/v2/logout', {}, {
      headers: { 
        Cookie: `.ROBLOSECURITY=${cookie}`,
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
      }
    });
  } catch (error) {
    if (error.response && error.response.headers['x-csrf-token']) {
      return error.response.headers['x-csrf-token'];
    }
  }
  return null;
}

// --- FUNCTION TO CHECK PRESENCE VIA ROBLOX API (MOST ACCURATE) ---
async function checkRobloxPresence(cookie, userId, pkg) {
  try {
    // Dapatkan CSRF token jika belum ada
    if (!csrfTokens[pkg]) {
      csrfTokens[pkg] = await getCsrfToken(cookie);
    }

    const presenceResponse = await axios.post('https://presence.roblox.com/v1/presence/users', 
      { userIds: [userId] },
      {
        headers: {
          'Cookie': `.ROBLOSECURITY=${cookie}`,
          'x-csrf-token': csrfTokens[pkg] || '',
          'Content-Type': 'application/json',
          'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
        }
      }
    );

    const presence = presenceResponse.data.userPresences[0];
    
    if (DEBUG_MODE) {
      console.log(`[DEBUG] ${pkg}: Roblox Presence Type: ${presence.userPresenceType}`);
    }
    
    // userPresenceType: 0=Offline, 1=Online, 2=In-Game, 3=Studio
    return {
      isInGame: presence.userPresenceType === 2,
      presenceType: presence.userPresenceType,
      lastLocation: presence.lastLocation,
      placeId: presence.placeId,
      gameId: presence.gameId
    };
  } catch (error) {
    if (error.response && error.response.status === 403) {
      // CSRF token expired, coba refresh
      csrfTokens[pkg] = await getCsrfToken(cookie);
      // Coba lagi sekali
      try {
        const retryResponse = await axios.post('https://presence.roblox.com/v1/presence/users', 
          { userIds: [userId] },
          {
            headers: {
              'Cookie': `.ROBLOSECURITY=${cookie}`,
              'x-csrf-token': csrfTokens[pkg] || '',
              'Content-Type': 'application/json'
            }
          }
        );
        const presence = retryResponse.data.userPresences[0];
        return {
          isInGame: presence.userPresenceType === 2,
          presenceType: presence.userPresenceType
        };
      } catch (retryError) {
        if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: Retry failed: ${retryError.message}`);
      }
    }
    
    if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: Presence check failed: ${error.message}`);
    return { isInGame: false, presenceType: 0 };
  }
}

