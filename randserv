async function getAppRamAsync(pkg) {
  try {
    const { stdout: pidOut } = await execAsync(`su -c "pidof ${pkg}"`);
    const pid = pidOut.trim();
    if (!pid) return "0 MB";
    
    const { stdout: statusOut } = await execAsync(`su -c "grep VmRSS /proc/${pid}/status"`);
    const match = statusOut.match(/\d+/);
    if (match) {
        const mb = (parseInt(match[0]) / 1024).toFixed(1);
        return `${mb} MB`;
    }
    return "N/A";
  } catch (e) {
    return "0 MB";
  }
}

