  const stats = getSystemStats();
  console.log(`📱 SYSTEM: CPU ${stats.cpu} | RAM ${stats.ram} | UP ${stats.uptime} | BOOSTER: ON 🔥`);
  console.log(`📏 MODE: XML GRID (${GRID_COLS} cols) | DETEKSI: ROBLOX API (1m cooldown)`);
  console.log(`📊 STATUS: ${statusMessage} | Mode: CONTINUOUS | Code: ${cleanCode}`);
  
  const termWidth = process.stdout.columns || 80;
  const safeWidth = Math.max(50, termWidth - 10); 

  const wPkg = Math.floor(safeWidth * 0.20);
  const wUser = Math.floor(safeWidth * 0.15);
  const wState = Math.floor(safeWidth * 0.12);
  const wStatus = Math.floor(safeWidth * 0.20);
  const wRam = 10;
  const wAction = Math.max(5, safeWidth - (wPkg + wUser + wState + wStatus + wRam));
  const table = new Table({ 
      head: ['Pkg', 'User', 'State', 'Status', 'RAM', 'Action'], 
      colWidths: [wPkg, wUser, wState, wStatus, wRam, wAction],
      wordWrap: true 
  });
  Object.keys(accountStates).sort().forEach(pkg => {
    const s = accountStates[pkg];
    table.push([
      pkg.replace("com.roblox.client", "...client"), 
      s.username.substring(0, 12),
      s.isRunning ? "Run 🟢" : "Wait ⚪",
      s.serverStatus,
      s.ramUsage,
      s.action
    ]);
  });
  console.log(table.toString());
}

async function main() {
  initSystem();
  startNetworkKeepAlive();

  console.clear();
  console.log("🚀 Initializing Manager (Continuous Mode)...");

  applyPerformanceTweaks();
  const packages = getPackages();
  if (!packages.length) { 
    console.log("❌ No Roblox packages found."); 
    process.exit(0);
  }

  let accounts = [];
  packages.sort();
  for (const pkg of packages) {
    process.stdout.write(`Reading ${pkg}... \r`);
    const cookie = getRobloxCookie(pkg);
    const userInfo = await getUserInfo(cookie);
    
    if (!userInfo.id || userInfo.name === "Expired") {
      console.log(`⚠️ Skipping ${pkg}: Cookie Expired atau Tidak Valid.`);
      continue; 
    }

    accounts.push({ pkg, cookie, userId: userInfo.id, username: userInfo.name });
    lastRestartMap[pkg] = 0;
    accountStates[pkg] = { username: userInfo.name, isRunning: false, serverStatus: "Waiting...", ramUsage: "0 MB", action: "-" };
    
    csrfTokens[pkg] = await getCsrfToken(cookie);
  }

  if (accounts.length === 0) {
    console.log("❌ Tidak ada akun valid untuk dijalankan.");
    process.exit(0);
  }

  const codes = await fetchLinkCodes();
  if (codes.length === 0) { 
    console.log("⚠️ No codes found."); 
    process.exit(1);
  }

  let cleanCode = "";
  if (!AUTO_RANDOM_CODE) {
    const argIndex = process.argv.indexOf("-server");
    let selectedIdx = -1;
    if (argIndex !== -1 && process.argv[argIndex + 1]) {
        selectedIdx = parseInt(process.argv[argIndex + 1]) - 1;
    }

    if (selectedIdx >= 0 && selectedIdx < codes.length) {
        cleanCode = codes[selectedIdx];
    } else {
        console.log("\n📜 Available Codes:");
        codes.forEach((code, index) => console.log(`[${index + 1}] ${code}`));
        
        const selection = await ask("\n👉 Choose Server: ");
        const idx = parseInt(selection) - 1;
        
        if (isNaN(idx) || idx < 0 || idx >= codes.length) {
            console.log("❌ Invalid selection.");
            process.exit(1);
        }
        cleanCode = codes[idx];
    }
  }

  const codeDisplay = AUTO_RANDOM_CODE ? "RANDOM" : `...${cleanCode.slice(-4)}`;
  
  // MENGATUR XML DAN MENGINJEKSI FASTFLAGS
  autoArrangeXML(accounts.map(a => a.pkg));
  injectFastFlags(accounts.map(a => a.pkg));

  // ==========================================
  // FASE 0: PRE-LAUNCH AWAL UNTUK SEMUA APLIKASI
  // ==========================================
  console.log("\n🚀 Fase 0: Pre-launch (Monkey) untuk semua aplikasi...");
  for (let i = 0; i < accounts.length; i++) {
    await ensureAppPreLaunched(accounts[i], codeDisplay);
  }

  // ==========================================
  // FASE 1: BYPASS CAPTCHA & INJECT LINKCODE
  // ==========================================
  console.log("\n🚀 Fase 1: Bypass Captcha & Join via LinkCode...");
  for (let i = 0; i < accounts.length; i++) {
    const acc = accounts[i];
    
    accountStates[acc.pkg].serverStatus = "Solving Challenge ⏳";
    renderDashboard(codeDisplay, `🤖 Mengecek cookie ${acc.username} sebelum request ke Wintercode API...`);
    
    await runSolver(acc.cookie, acc.pkg);
    renderDashboard(codeDisplay, `✅ Checker & Solver selesai untuk ${acc.username}. Injecting LinkCode...`);
    await sleep(2000); 

    let currentCode = AUTO_RANDOM_CODE ? codes[Math.floor(Math.random() * codes.length)] : cleanCode;
    if(currentCode.includes("linkCode=")) {
        currentCode = currentCode.split("linkCode=")[1].split("&")[0];
    }
    const finalLaunchUrl = `roblox://placeID=${PLACE_ID}&linkCode=${currentCode}`;
    
    let isStable = false;
    let isFirstTry = true; 
    let joinAttempt = 0;

    while (!isStable && joinAttempt < MAX_LOOP_ATTEMPTS) {
      joinAttempt++;
      if (!isFirstTry) {
          await stopPackageAsync(acc.pkg); 
          await releaseMemoryAsync();
          await sleep(1500); 
          
          const preLaunchOk = await ensureAppPreLaunched(acc, codeDisplay);
          if (!preLaunchOk) break; 
      }

      await launchPackageAsync(acc.pkg, finalLaunchUrl);
      lastRestartMap[acc.pkg] = Date.now();
      accountStates[acc.pkg].isRunning = true;
      accountStates[acc.pkg].serverStatus = `Joining Game... (Try ${joinAttempt})`;
      
      renderDashboard(codeDisplay, `🚀 App ${acc.username} terbuka. Memberikan waktu napas (15s)...`);
      await sleep(15000); 
      
      await protectProcessFromLMKAsync(acc.pkg);
      
      let crashed = false;
      for (let sec = 1; sec <= 15; sec++) { 
        if (sec % 2 === 0) { 
          await refreshRamUsage(acc.pkg);
        }
        
        renderDashboard(codeDisplay, `⏳ ${acc.username} Stabilizing... (${sec * 4}/60s) 🛡️ Shield ON`);
        await sleep(4000); 

        const healthCheck = await isAppHealthy(acc.pkg, acc.cookie, acc.userId);
        
        if (!healthCheck.healthy) {
            accountStates[acc.pkg].serverStatus = `Crash: ${healthCheck.reason}`;
            await refreshRamUsage(acc.pkg);
            renderDashboard(codeDisplay, `⚠️ ${acc.username} ${healthCheck.reason} di detik ${sec * 4}! Membuka ulang...`);
            crashed = true;
            await sleep(3000); 
            break;
        } else if (healthCheck.loading) {
            accountStates[acc.pkg].serverStatus = `⏳ ${healthCheck.reason}`;
        }
      }

      if (!crashed) {
        accountStates[acc.pkg].serverStatus = "In Game 🎮 (Stable)";
        await refreshRamUsage(acc.pkg);
        renderDashboard(codeDisplay, `✅ ${acc.username} Stabil! Lanjut ke akun berikutnya...`);
        isStable = true; 
        await sleep(2000);
      }
      
      isFirstTry = false; 
    }
    
    if (!isStable) {
       accountStates[acc.pkg].serverStatus = "❌ Gagal Join (Max Retries)";
       accountStates[acc.pkg].isRunning = false;
    }
  }

  // ==========================================
  // FASE 2: CONTINUOUS MONITORING
  // ==========================================
  console.log("\n🔄 Memasuki Mode Continuous Monitoring...");
  await releaseMemoryAsync();
  
  while (true) {
    let anyCrashed = false;
    for (let i = 0; i < accounts.length; i++) {
        const acc = accounts[i];
        
        if (accountStates[acc.pkg].serverStatus.includes("Gagal Join")) continue;

        renderDashboard(codeDisplay, `🔒 Cek validitas cookie ${acc.username}...`);
        const cookieStatus = await getUserInfo(acc.cookie);
        if (!cookieStatus.id || cookieStatus.name === "Expired") {
            accountStates[acc.pkg].serverStatus = "❌ Invalid/Banned (403)";
            accountStates[acc.pkg].isRunning = false;
            accountStates[acc.pkg].ramUsage = "0 MB";
            accountStates[acc.pkg].action = "Skipped";
            await stopPackageAsync(acc.pkg); 
            await sleep(2000);
            continue;
        }

        renderDashboard(codeDisplay, `👀 Mengecek status ${acc.username}...`);
        await sleep(2000); 

        await refreshRamUsage(acc.pkg);
        const healthCheck = await isAppHealthy(acc.pkg, acc.cookie, acc.userId);
        
        if (healthCheck.healthy) {
          accountStates[acc.pkg].isRunning = true;
          if (healthCheck.loading) {
            accountStates[acc.pkg].serverStatus = `⏳ ${healthCheck.reason}`;
          } else {
            accountStates[acc.pkg].serverStatus = "In Game 🎮 (Monitoring)";
          }
          accountStates[acc.pkg].action = `✅ ${healthCheck.ram}MB`;
        } else {
          anyCrashed = true;
          let isStable = false;
          let currentCrashReason = healthCheck.reason;
          let recoveryAttempt = 0;

          while (!isStable && recoveryAttempt < MAX_LOOP_ATTEMPTS) {
              recoveryAttempt++;
              accountStates[acc.pkg].isRunning = false;
              accountStates[acc.pkg].serverStatus = `⚠️ ${currentCrashReason} - Reopening (Try ${recoveryAttempt})...`;
              accountStates[acc.pkg].ramUsage = "0 MB";
              accountStates[acc.pkg].action = `⚠️ ${currentCrashReason}`;

              await stopPackageAsync(acc.pkg);
              await releaseMemoryAsync();
              await sleep(1500);

              const preLaunchOk = await ensureAppPreLaunched(acc, codeDisplay);
              if (!preLaunchOk) break;

              accountStates[acc.pkg].serverStatus = "Solving Challenge ⏳";
              renderDashboard(codeDisplay, `🤖 Mengecek cookie ${acc.username} sebelum request ke Wintercode API...`);
              await runSolver(acc.cookie, acc.pkg);
              
              let currentCode = AUTO_RANDOM_CODE ? codes[Math.floor(Math.random() * codes.length)] : cleanCode;
              if(currentCode.includes("linkCode=")) {
                  currentCode = currentCode.split("linkCode=")[1].split("&")[0];
              }
              const finalLaunchUrl = `roblox://placeID=${PLACE_ID}&linkCode=${currentCode}`;
              
              await launchPackageAsync(acc.pkg, finalLaunchUrl);
              
              renderDashboard(codeDisplay, `🚀 App ${acc.username} terbuka. Memberikan waktu napas (15s)...`);
              await sleep(15000); 

              await protectProcessFromLMKAsync(acc.pkg);
              
              let crashedDuringRecovery = false;
              for(let w = 1; w <= 15; w++) { 
                  if (w % 2 === 0) {
                    await refreshRamUsage(acc.pkg);
                  }
                  renderDashboard(codeDisplay, `⏳ Stabilizing ${acc.username}... (${w * 4}/60s) 🛡️ Shield ON`);
                  await sleep(4000); 

                  const recoveryHealth = await isAppHealthy(acc.pkg, acc.cookie, acc.userId);
                  if (!recoveryHealth.healthy) {
                      currentCrashReason = recoveryHealth.reason;
                      accountStates[acc.pkg].serverStatus = `Crash: ${currentCrashReason}`;
                      await refreshRamUsage(acc.pkg);
                      crashedDuringRecovery = true;
                      await sleep(3000);
                      break; 
                  } else if (recoveryHealth.loading) {
                      accountStates[acc.pkg].serverStatus = `⏳ ${recoveryHealth.reason}`;
                  }
              }
              
              if (!crashedDuringRecovery) {
                  await refreshRamUsage(acc.pkg);
                  accountStates[acc.pkg].isRunning = true;
                  accountStates[acc.pkg].serverStatus = "In Game 🎮 (Recovered)";
                  accountStates[acc.pkg].action = "Recovered";
                  isStable = true;
                  await sleep(2000);
              }
          }
          
          if (!isStable) {
             accountStates[acc.pkg].serverStatus = "❌ Gagal Recovery (Max Retries)";
             accountStates[acc.pkg].isRunning = false;
          }
        }
    }

    if (anyCrashed) {
        await releaseMemoryAsync();
    }

    renderDashboard(codeDisplay, `👀 Monitoring Selesai | Next check in ${CHECK_INTERVAL/1000}s`);
    await sleep(CHECK_INTERVAL); 
  }
}

main();
