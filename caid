#!/data/data/com.termux/files/usr/bin/bash

# ===== DETECT TERMINAL WIDTH (REALTIME) =====
get_width() {
    local w
    w=$(tput cols 2>/dev/null)
    [ -z "$w" ] && w=$(stty size 2>/dev/null | awk '{print $2}')
    [ -z "$w" ] && w=60
    [ "$w" -lt 50 ] && w=50
    echo "$w"
}

COLS=$(get_width)

# Proporsional otomatis
KEY_LEN=$((COLS / 4))
VAL_LEN=$((COLS - KEY_LEN - 7))

# ===== WARNA =====
C='\033[1;36m'
G='\033[1;32m'
Y='\033[1;33m'
NC='\033[0m'

draw_line() {
    printf "+"
    printf "%0.s-" $(seq 1 $((COLS-2)))
    printf "+\n"
}

print_row() {
    local key="$1"
    local val="$2"

    printf "| ${C}%-${KEY_LEN}s${NC} | ${G}%-${VAL_LEN}s${NC} |\n" "$key" "$val"
}

print_center() {
    local text="$1"
    local pad=$(( (COLS - ${#text}) / 2 ))
    printf "%*s%s\n" $pad "" "$text"
}

# ===== AMBIL DATA =====
MODEL=$(getprop ro.product.model | tr -d '\r\n')
BRAND=$(getprop ro.product.brand | tr -d '\r\n')
BOARD=$(getprop ro.board.platform | tr -d '\r\n')
AID=$(settings get secure android_id | tr -d '\r\n')
SERIAL=$(getprop ro.serialno | tr -d '\r\n')
MAC=$(cat /sys/class/net/wlan0/address 2>/dev/null | tr -d '\r\n')
[ -z "$MAC" ] && MAC="Not Available"
IMEI=$(su -c "service call iphonesubinfo 1" 2>/dev/null | awk -F "'" '{print $2}' | sed 's/\.//g' | tr -d '\r\n' | cut -c1-15)
[ -z "$IMEI" ] && IMEI="Permission Denied"

clear

draw_line
print_center "${Y}DEVICE INFORMATION${NC}"
draw_line

print_row "Device" "$MODEL"
print_row "Brand" "$BRAND"
print_row "Board" "$BOARD"
print_row "Android ID" "$AID"
print_row "Serial" "$SERIAL"
print_row "MAC Address" "$MAC"
print_row "IMEI" "$IMEI"

draw_line
echo
