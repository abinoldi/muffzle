#!/data/data/com.termux/files/usr/bin/bash

# ===== GET TERMINAL WIDTH =====
get_width() {
    local w
    w=$(tput cols 2>/dev/null)
    [ -z "$w" ] && w=$(stty size 2>/dev/null | awk '{print $2}')
    [ -z "$w" ] && w=60
    [ "$w" -lt 50 ] && w=50
    echo "$w"
}

COLS=$(get_width)

# ===== COLORS =====
C='\033[1;36m'
G='\033[1;32m'
Y='\033[1;33m'
NC='\033[0m'

# ===== CENTER TEXT =====
center() {
    local text="$1"
    local pad=$(( (COLS - ${#text}) / 2 ))
    printf "%*s%s\n" $pad "" "$text"
}

# ===== PRINT LINE SEPARATOR =====
line() {
    printf "%0.s─" $(seq 1 $COLS)
    echo
}

# ===== PRINT ITEM =====
print_item() {
    local key="$1"
    local val="$2"
    printf "${C}%-15s${NC} : ${G}%s${NC}\n" "$key" "$val"
}

# ===== GET DEVICE DATA =====
MODEL=$(getprop ro.product.model | tr -d '\r\n')
BRAND=$(getprop ro.product.brand | tr -d '\r\n')
BOARD=$(getprop ro.board.platform | tr -d '\r\n')
AID=$(settings get secure android_id | tr -d '\r\n')
SERIAL=$(getprop ro.serialno | tr -d '\r\n')
MAC=$(cat /sys/class/net/wlan0/address 2>/dev/null | tr -d '\r\n')
[ -z "$MAC" ] && MAC="Not Available"
IMEI=$(su -c "service call iphonesubinfo 1" 2>/dev/null | awk -F "'" '{print $2}' | sed 's/\.//g' | tr -d '\r\n' | cut -c1-15)
[ -z "$IMEI" ] && IMEI="Permission Denied"

clear

line
center "${Y}DEVICE INFORMATION${NC}"
line
echo

print_item "Device" "$MODEL"
print_item "Brand" "$BRAND"
print_item "Board" "$BOARD"
print_item "Android ID" "$AID"
print_item "Serial" "$SERIAL"
print_item "MAC Address" "$MAC"
print_item "IMEI" "$IMEI"

echo
line
echo
