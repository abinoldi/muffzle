#!/data/data/com.termux/files/usr/bin/bash

# Ambil data device
MODEL=$(getprop ro.product.model)
BRAND=$(getprop ro.product.brand)
BOARD=$(getprop ro.board.platform)
ANDROID_ID=$(settings get secure android_id)
SERIAL=$(getprop ro.serialno)
MAC=$(cat /sys/class/net/wlan0/address 2>/dev/null || echo "02:00:00:00:00:00")

# Ambil IMEI (Memerlukan Root)
IMEI=$(su -c "service call iphonesubinfo 1 | awk -F \"'\" '{print \$2}' | sed 's/\.//g' | tr -d '\n'")

echo "------------------------------------------"
echo "Device     : $MODEL"
echo "Brand      : $BRAND"
echo "Board      : $BOARD"
echo "Android ID : $ANDROID_ID"
echo "Serial     : $SERIAL"
echo "MAC        : $MAC"
echo "IMEI       : $IMEI"
echo "------------------------------------------"
