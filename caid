#!/data/data/com.termux/files/usr/bin/bash

# Ambil lebar terminal
COLS=$(tput cols 2>/dev/null)
[ -z "$COLS" ] && COLS=60
[ "$COLS" -lt 50 ] && COLS=50

# Garis separator
LINE=$(printf "%0.s-" $(seq 1 $COLS))

# Ambil data
DEVICE=$(getprop ro.product.name | tr -d '\r\n')
MODEL=$(getprop ro.product.model | tr -d '\r\n')
BRAND=$(getprop ro.product.brand | tr -d '\r\n')
BOARD=$(getprop ro.board.platform | tr -d '\r\n')
ANDROID_ID=$(settings get secure android_id | tr -d '\r\n')
SERIAL=$(getprop ro.serialno | tr -d '\r\n')
MAC=$(cat /sys/class/net/wlan0/address 2>/dev/null | tr -d '\r\n')
IMEI=$(su -c "service call iphonesubinfo 1" 2>/dev/null | awk -F "'" '{print $2}' | sed 's/\.//g' | cut -c1-15)

clear

echo "License     : Tidak terdeteksi"
echo "$LINE"
echo
echo "PROFIL SET 7/8 (Grup 7)"
echo "$LINE"

printf "%-12s : %s\n" "Device" "$DEVICE"
printf "%-12s : %s\n" "Model" "$MODEL"
printf "%-12s : %s\n" "Brand" "$BRAND"
printf "%-12s : %s\n" "Board" "$BOARD"
printf "%-12s : %s\n" "Android ID" "$ANDROID_ID"
printf "%-12s : %s\n" "Serial" "$SERIAL"
printf "%-12s : %s\n" "MAC" "$MAC"
printf "%-12s : %s\n" "IMEI baru" "$IMEI"
printf "%-12s : %s\n" "License" "-"
printf "%-12s : %s\n" "IMEI skrg" "$IMEI"

echo "$LINE"
echo
echo -n "Apply FULL SPOOF? (y/n) > "
