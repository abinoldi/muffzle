#!/data/data/com.termux/files/usr/bin/bash

# Ambil lebar terminal
COLS=$(tput cols 2>/dev/null)
[ -z "$COLS" ] && COLS=60
[ "$COLS" -lt 50 ] && COLS=50

KEY_LEN=14
VAL_LEN=$((COLS - KEY_LEN - 7))

# Warna
C='\033[1;36m'   # Bold Cyan
G='\033[1;32m'   # Bold Green
Y='\033[1;33m'   # Bold Yellow
NC='\033[0m'

draw_line() {
    printf "+-%-${KEY_LEN}s-+-%-${VAL_LEN}s-+\n" \
        "$(printf "%${KEY_LEN}s" | tr ' ' '-')" \
        "$(printf "%${VAL_LEN}s" | tr ' ' '-')"
}

print_center() {
    local text="$1"
    local padding=$(( (COLS - ${#text}) / 2 ))
    printf "%*s%s\n" $padding "" "$text"
}

print_row() {
    local key="$1"
    local val="$2"

    # Wrap otomatis jika terlalu panjang
    while [ -n "$val" ]; do
        local chunk="${val:0:$VAL_LEN}"
        val="${val:$VAL_LEN}"
        printf "| ${C}%-${KEY_LEN}s${NC} | ${G}%-${VAL_LEN}s${NC} |\n" "$key" "$chunk"
        key=""
    done
}

# Ambil data
MODEL=$(getprop ro.product.model | tr -d '\r\n')
BRAND=$(getprop ro.product.brand | tr -d '\r\n')
BOARD=$(getprop ro.board.platform | tr -d '\r\n')
AID=$(settings get secure android_id | tr -d '\r\n')
SERIAL=$(getprop ro.serialno | tr -d '\r\n')
MAC=$(cat /sys/class/net/wlan0/address 2>/dev/null | tr -d '\r\n')
[ -z "$MAC" ] && MAC="Not Available"
IMEI=$(su -c "service call iphonesubinfo 1" 2>/dev/null | awk -F "'" '{print $2}' | sed 's/\.//g' | tr -d '\r\n' | cut -c1-15)
[ -z "$IMEI" ] && IMEI="Permission Denied"

clear

print_center "${Y}DEVICE INFORMATION${NC}"
echo
draw_line
print_row "Device" "$MODEL"
print_row "Brand" "$BRAND"
print_row "Board" "$BOARD"
print_row "Android ID" "$AID"
print_row "Serial" "$SERIAL"
print_row "MAC Address" "$MAC"
print_row "IMEI" "$IMEI"
draw_line
echo
