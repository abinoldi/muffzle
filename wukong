-- // FUNGSI VALIDASI TRADE //
local function isTradeRequest(button)
    local current = button.Parent
    local maxIterations = 10
    local iterations = 0
    while current and iterations < maxIterations do
        local label = current:FindFirstChild("Label") or current:FindFirstChild("TextLabel")
        if label and label:IsA("TextLabel") then
            local text = label.Text:lower()
            if text:find("from") or text:find("give") or text:find("trade") then
                return true
            end
        end
        current = current.Parent
        iterations = iterations + 1
    end
    -- Mengembalikan true jika validasi di atas tidak menemukan teks spesifik, 
    -- namun tombol bernama "Yes" tetap muncul.
    return true 
end

-- // FUNGSI SAFE CLICK (BYPASS VIRTUAL INPUT MANAGER) //
local function SafeClick(button)
    local success = pcall(function()
        if getconnections then
            -- Menembak (Fire) semua jenis koneksi klik tanpa mouse fisik
            for _, connection in pairs(getconnections(button.MouseButton1Click)) do
                connection:Fire()
            end
            for _, connection in pairs(getconnections(button.Activated)) do
                connection:Fire()
            end
            for _, connection in pairs(getconnections(button.MouseButton1Down)) do
                connection:Fire()
            end
            for _, connection in pairs(getconnections(button.MouseButton1Up)) do
                connection:Fire()
            end
        else
            warn("⚠️ Executor kamu tidak mendukung 'getconnections'.")
        end
    end)
    
    if success then
        print("✅ Tombol 'Yes' berhasil diklik secara aman (UI Firing)")
    else
        warn("❌ Gagal melakukan SafeClick.")
    end
end

