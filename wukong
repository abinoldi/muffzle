-- // FUNGSI UNTUK MENDAPATKAN POSISI BUTTON //
local function getButtonRect(button)
    if not (button and button.Visible and button.AbsoluteSize.Magnitude > 0) then return nil end
    local absPos = button.AbsolutePosition
    local absSize = button.AbsoluteSize
    local guiInset = GuiService:GetGuiInset()
    return { X = absPos.X, Y = absPos.Y + guiInset.Y, W = absSize.X, H = absSize.Y }
end

-- // FUNGSI KLIK SIMULASI (VIRTUAL INPUT) //
local function clickXY(x, y)
    VirtualInputManager:SendMouseMoveEvent(x, y, game)
    task.wait(0.02)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.02)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    print("🖱️ Clicked at:", x, y)
end

-- // FUNGSI VALIDASI TRADE //
local function isTradeRequest(button)
    local current = button.Parent
    local maxIterations = 10
    local iterations = 0
    while current and iterations < maxIterations do
        local label = current:FindFirstChild("Label") or current:FindFirstChild("TextLabel")
        if label and label:IsA("TextLabel") then
            local text = label.Text:lower()
            if text:find("from") or text:find("give") or text:find("trade") then
                return true
            else
                return false
            end
        end
        current = current.Parent
        iterations = iterations + 1
    end
    return true
end

