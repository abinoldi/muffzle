-- ======================================================
-- AUTO ACCEPT TRADE & TELEPORT (ADVANCED HOOK MODE)
-- 100% NO VIM | RANDOM DELAY 3-4s | ANTI-AFK | AUTO-DISCONNECT
-- ======================================================

-- // 0. KONFIGURASI TELEPORT //
_G.FishItConfig = {
    -- Pilih mode teleportasi: "Ancient Ruin" atau "Player"
    TeleportMode = "Ancient Ruin", 
    
    Locations = {
        ["Ancient Ruin"] = {
            Pos = Vector3.new(6031.981, -585.924, 4713.157), 
            Look = Vector3.new(0.316, -0.000, -0.949)
        }
    }
}

local lastTradeTime = tick() -- Mencatat waktu awal saat script dijalankan
local IDLE_LIMIT = 30 -- Batas waktu 30 detik (30 detik)

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

---------------------------------------------------------
print("--- 🤖 MENGINISIALISASI SCRIPT ---")
---------------------------------------------------------

-- // 1. FUNGSI TELEPORT (Berdasarkan Config) //
task.spawn(function()
    while task.wait(10) do -- Looping terus-menerus dengan delay 10 detik
        local myChar = LocalPlayer.Character
        
        -- Pastikan karakter kita ada dan memiliki HumanoidRootPart
        if myChar and myChar:FindFirstChild("HumanoidRootPart") then
            local myHRP = myChar.HumanoidRootPart
            local mode = _G.FishItConfig.TeleportMode
            
            if mode == "Ancient Ruin" then
                -- Teleport ke lokasi statis Ancient Ruin
                local locData = _G.FishItConfig.Locations["Ancient Ruin"]
                local success, err = pcall(function()
                    -- Membuat CFrame berdasarkan Posisi dan arah pandang (Look Vector)
                    myHRP.CFrame = CFrame.new(locData.Pos, locData.Pos + locData.Look)
                end)
                
                if success then
                    print("📍 [LOOP] Teleportasi selesai ke: Ancient Ruin")
                end
                
            elseif mode == "Player" then
                -- Teleport ke Random Player
                local playersList = Players:GetPlayers()
                local validTargets = {}
                
                -- Memfilter player: Kecualikan diri sendiri dan pastikan mereka punya karakter
                for _, p in ipairs(playersList) do
                    if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        table.insert(validTargets, p)
                    end
                end
                
                -- Jika ada player lain di server yang valid
                if #validTargets > 0 then
                    -- Pilih satu player secara acak
                    local targetPlayer = validTargets[math.random(1, #validTargets)]
                    local targetHRP = targetPlayer.Character.HumanoidRootPart
                    
                    -- Teleport dengan pengamanan pcall agar tidak error jika target tiba-tiba hilang
                    local success, err = pcall(function() 
                        -- Teleport ke player tersebut dengan offset 3 stud ke belakang
                        myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3) 
                    end)
                    
                    if success then
                        print("📍 [LOOP] Teleportasi selesai ke player: " .. targetPlayer.Name)
                    end
                else
                    warn("⚠️ [LOOP] Tidak ada player lain di server saat ini.")
                end
            end
        end
    end
end)

-- // 2. LOAD MODULES & HOOK PROMPT CONTROLLER //
local Promise, PromptController
local modulesLoaded = pcall(function()
    Promise = require(ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Promise"))
    PromptController = require(ReplicatedStorage:WaitForChild("Controllers"):WaitForChild("PromptController"))
end)

if modulesLoaded and PromptController and Promise then
    if not getgenv().oldFirePrompt then
        getgenv().oldFirePrompt = PromptController.FirePrompt
    end
    
    -- Membajak fungsi asli PromptController
    hookfunction(PromptController.FirePrompt, function(self, promptText, ...)
        if type(promptText) == "string" then
            local textLower = promptText:lower()
            
            if (textLower:find("accept") and textLower:find("from:")) or textLower:find("to give") or textLower:find("trade") then
                
                -- RESET WAKTU KARENA ADA AKTIVITAS TRADE
                lastTradeTime = tick()
                
                -- JEDA ACAK 3.0 HINGGA 4.0 DETIK
                local randomDelay = math.random(30, 40) / 10
                
                warn("⏳ [HOOK] Trade masuk! Menunggu " .. randomDelay .. " detik agar natural...")
                
                return Promise.new(function(resolve)
                    task.wait(randomDelay) 
                    resolve(true) 
                    warn("✅ [SUCCESS] Trade otomatis di-Accept setelah " .. randomDelay .. " detik!")
                end)
            end
        end
        
        return getgenv().oldFirePrompt(self, promptText, ...)
    end)
    
    print("🚀 [SUCCESS] Auto Accept Trade Hook Aktif (Random Delay 3-4s)!")
else
    warn("❌ Gagal memuat module PromptController/Promise.")
end

-- // 3. ANTI-AFK (GETCONNECTIONS IDLED) //
pcall(function()
    if getconnections then
        for _, connection in pairs(getconnections(LocalPlayer.Idled)) do
            if connection.Disable then
                connection:Disable()
            end
        end
        print("🛡️ [SUCCESS] Anti-AFK (Idled GetConnections) Aktif! Kamu tidak akan ter-kick karena diam.")
    else
        warn("⚠️ Executor kamu tidak mendukung getconnections untuk Anti-AFK.")
    end
end)

-- // 4. AUTO DISCONNECT JIKA TIDAK ADA TRADE (5 MENIT) //
task.spawn(function()
    while task.wait(5) do -- Mengecek setiap 5 detik agar tidak memberatkan performa
        local timeSinceLastTrade = tick() - lastTradeTime
        
        if timeSinceLastTrade >= IDLE_LIMIT then
            warn("⚠️ Tidak ada trade selama 5 menit. Memaksa keluar ke Home...")
            task.wait(1)
            -- Menggunakan Kick() untuk mengembalikan akun ke layar Home Roblox dengan aman
            LocalPlayer:Kick("Tidak ada aktivitas trade selama 5 menit. Auto-disconnect.")
            break -- Menghentikan loop pengecekan
        end
    end
end)
