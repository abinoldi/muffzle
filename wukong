-- ======================================================
-- 1. MEMBUAT ILUSI KURSOR MOUSE (VISUAL)
-- ======================================================
local fakeMouseGui = Instance.new("ScreenGui")
fakeMouseGui.Name = "FakeMouseIllusion"
fakeMouseGui.IgnoreGuiInset = true
fakeMouseGui.ZIndexBehavior = Enum.ZIndexBehavior.Global

-- Coba simpan di CoreGui agar tidak hilang saat reset
local successCoreGui = pcall(function() fakeMouseGui.Parent = CoreGui end)
if not successCoreGui then fakeMouseGui.Parent = PlayerGui end

local fakeCursor = Instance.new("ImageLabel")
