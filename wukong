-- // FUNGSI TELEPORT AMAN (2x CONFIRMATION) //
task.spawn(function()
    local locData = locations["Treasure Room"]
    local myChar = LocalPlayer.Character
    
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
        local myHRP = myChar.HumanoidRootPart
        
        for i = 1, 2 do
            pcall(function()
                myHRP.CFrame = CFrame.new(locData.Pos, locData.Pos + locData.Look)
                print("📍 [Teleport " .. i .. "/2] Memindahkan ke: Treasure Room")
            end)
            if i == 1 then task.wait(1) end
        end
        print("✅ Teleportasi selesai dan dikonfirmasi!")
    else
        warn("⚠️ Gagal Teleport: Karakter belum siap.")
    end
end)

-- // FUNGSI VALIDASI TRADE //
local function isTradeRequest(button)
    local current = button.Parent
    local maxIterations = 10
    local iterations = 0
    while current and iterations < maxIterations do
        local label = current:FindFirstChild("Label") or current:FindFirstChild("TextLabel")
        if label and label:IsA("TextLabel") then
            local text = label.Text:lower()
            if text:find("from") or text:find("give") or text:find("trade") then
                return true
            end
        end
        current = current.Parent
        iterations = iterations + 1
    end
    return true 
end

-- // FUNGSI VIRTUAL MOUSE CLICK (TERLIHAT VISUAL) //
local function VirtualClick(button)
    -- Pastikan tombol ada dan terlihat di layar
    if not (button and button.Visible and button.AbsoluteSize.Magnitude > 0) then return end
    
    -- Dapatkan kompensasi Topbar Roblox agar klik tidak meleset
    local inset, _ = GuiService:GetGuiInset()
    
    -- Hitung koordinat X dan Y tepat di tengah tombol
    local centerX = button.AbsolutePosition.X + (button.AbsoluteSize.X / 2)
    local centerY = button.AbsolutePosition.Y + (button.AbsoluteSize.Y / 2) + inset.Y

    -- 1. Pindahkan mouse virtual ke tengah tombol
    VirtualInputManager:SendMouseMoveEvent(centerX, centerY, game)
    task.wait(0.1) -- Jeda agar efek "Hover" UI sempat muncul
    
    -- 2. Tekan klik kiri bawah (Down)
    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 0)
    task.wait(0.1) -- Tahan sedikit layaknya jari manusia
    
    -- 3. Lepaskan klik kiri (Up)
    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 0)
    
    -- Mouse sengaja TIDAK dipindahkan lagi agar kamu bisa melihatnya diam di atas tombol Yes
    print("🖱️ Mouse Virtual mengklik di koordinat: X=" .. math.floor(centerX) .. ", Y=" .. math.floor(centerY))
end

-- // MAIN LOOP SCANNER (AUTO ACCEPT) //
task.spawn(function()
    while true do
        pcall(function()
            local prompt = PlayerGui:FindFirstChild(TARGET_GUI)
            if prompt and prompt.Enabled then
                for _, obj in ipairs(prompt:GetDescendants()) do
                    -- Cek tombol target
                    if obj.Name == TARGET_BUTTON and (obj:IsA("ImageButton") or obj:IsA("TextButton")) and obj.Visible then
                        if isTradeRequest(obj) then
                            warn("✅ TRADE DETECTED! Menggerakkan mouse ke tombol Yes...")
                            
                            -- Panggil fungsi Virtual Click
                            VirtualClick(obj)
                            
                            -- Jeda acak 1.5 - 2.0 detik
                            local randomClickDelay = math.random(15, 20) / 10 
                            print("⏳ Menunggu " .. randomClickDelay .. " detik sebelum iterasi berikutnya...")
                            task.wait(randomClickDelay)
                        end
                    end
                end
            end
        end)
        task.wait(0.5) -- Scan UI setiap 0.5 detik
    end
end)

