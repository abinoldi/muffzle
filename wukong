-- ======================================================
-- FUNGSI MAPPING ENCODED (TEMUAN i + 1)
-- ======================================================
local function getEncodedRemote(originalName)
    local net = ReplicatedStorage:FindFirstChild("Packages")
    if net then
        net = net:FindFirstChild("_Index")
        if net then
            net = net:FindFirstChild("sleitnick_net@0.2.0")
            if net then
                net = net:FindFirstChild("net")
                if net then
                    local children = net:GetChildren()
                    for i = 1, #children do
                        if children[i].Name == originalName then
                            -- Langsung ambil objek setelahnya sesuai mapping i + 1
                            return children[i + 1]
                        end
                    end
                end
            end
        end
    end
    return nil
end

-- ======================================================
-- FUNGSI GETREMOTE (MENGGUNAKAN ENCODED)
-- ======================================================
local function GetRemote(name)
    return getEncodedRemote(name)
end

