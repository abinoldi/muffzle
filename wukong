fakeCursor.Size = UDim2.new(0, 30, 0, 30) 
fakeCursor.BackgroundTransparency = 1
fakeCursor.Image = "rbxasset://textures/Cursors/KeyboardMouse/ArrowCursor.png"
fakeCursor.ZIndex = 999999
fakeCursor.Visible = false
fakeCursor.Parent = fakeMouseGui

-- ======================================================
-- 2. FUNGSI TELEPORT AMAN (2x CONFIRMATION)
-- ======================================================
task.spawn(function()
    local locData = locations["Treasure Room"]
    local myChar = LocalPlayer.Character
    
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
