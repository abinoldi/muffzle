-- // FUNGSI BLINK TELEPORT (TELEPORT BERTAHAP) //
local function blinkTeleport(targetCFrame)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local hrp = char.HumanoidRootPart
    local startPos = hrp.Position
    local targetPos = targetCFrame.Position
    local distance = (targetPos - startPos).Magnitude
    
    -- Hitung butuh berapa kali lompatan
    local steps = math.ceil(distance / STEP_DISTANCE)
    
    print("🚀 Memulai Blink Teleport! Jarak: " .. math.floor(distance) .. " studs | Lompatan: " .. steps .. "x")
    
    -- Matikan pergerakan physics sementara agar tidak jatuh ke bawah map
    hrp.Anchored = true 
    
    for i = 1, steps do
        local alpha = i / steps
        -- Mencari titik di antara posisi awal dan akhir (Lerp)
        local nextPos = startPos:Lerp(targetPos, alpha)
        
        -- Gabungkan posisi baru dengan rotasi arah pandangan target
        local nextCFrame = CFrame.new(nextPos) * targetCFrame.Rotation
        
        char:PivotTo(nextCFrame)
        task.wait(STEP_DELAY) -- Jeda kilat agar anti-cheat sempat mendaftarkan posisi baru
    end
    
    hrp.Anchored = false
    print("📍 [AMAN] Berhasil tiba di lokasi tanpa tenggelam!")
end

