-- ======================================================
-- AUTO ACCEPT TRADE & TELEPORT (PROMPT HOOKING MODE)
-- 100% UNDETECTED | NO VIRTUAL INPUT | DOUBLE TELEPORT
-- ======================================================

-- // DATA LOKASI //
local locations = {
    ["Treasure Room"] = {
        Pos = Vector3.new(-3561.297, -279.074, -1606.289), 
        Look = Vector3.new(-0.782, -0.000, -0.623)
    }
}

-- // SERVICES //
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

---------------------------------------------------------
print("--- 🤖 SCRIPT TER-EXECUTE ---")

game:GetService("StarterGui"):SetCore("SendNotification", {
    Title = "Script Loaded";
    Text = "Menyiapkan Auto-Accept (Hook Mode)...";
    Duration = 3;
})

task.wait(3) 
print("--- 🚀 MEMULAI AUTO-ACCEPT & DOUBLE TELEPORT ---")
---------------------------------------------------------

-- // 1. FUNGSI TELEPORT AMAN (2x CONFIRMATION) //
task.spawn(function()
    local locData = locations["Treasure Room"]
    local myChar = LocalPlayer.Character
    
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
        local myHRP = myChar.HumanoidRootPart
        
        for i = 1, 2 do
            pcall(function()
                myHRP.CFrame = CFrame.new(locData.Pos, locData.Pos + locData.Look)
                print("📍 [Teleport " .. i .. "/2] Memindahkan ke: Treasure Room")
            end)
            if i == 1 then task.wait(1) end -- Jeda agar map terender
        end
        print("✅ Teleportasi selesai dan dikonfirmasi!")
    else
        warn("⚠️ Gagal Teleport: Karakter belum siap.")
    end
end)

-- // 2. HOOKING PROMPT CONTROLLER (AUTO ACCEPT) //
local success, err = pcall(function()
    -- Load modules game yang mengontrol Prompt dan Promise
    local PromptController = require(ReplicatedStorage:WaitForChild("Controllers"):WaitForChild("PromptController"))
    local Promise = require(ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Promise"))

    -- Simpan fungsi asli ke dalam memori
    local oldFirePrompt = PromptController.FirePrompt

    -- Overwrite (Bungkus) fungsi FirePrompt
    PromptController.FirePrompt = function(self, promptText, ...)
        
        -- Cek apakah text yang muncul adalah permintaan Trade
        if type(promptText) == "string" and (promptText:lower():find("trade") or promptText:lower():find("from") or promptText:lower():find("give")) then
            
            -- Ekstrak nama pengirim (opsional untuk log)
            local initiatorName = string.match(promptText, "from: ([^\n]+)") or "Seseorang"
            warn(string.format("✅ [AUTO ACCEPT] Menerima trade dari: %s", initiatorName))
            
            -- Mengembalikan Promise yang langsung "True" (Seolah-olah user menekan YES)
            return Promise.new(function(resolve)
                -- Tambahkan jeda acak 1.5 - 2.5 detik agar terlihat seperti manusia membaca
                local delayTime = math.random(15, 25) / 10
                print("⏳ Menunggu " .. delayTime .. " detik sebelum Accept otomatis...")
                task.wait(delayTime)
                
                -- Resolve(true) akan memicu game untuk mengirim remote accept trade sendiri!
                resolve(true)
            end)
        end
        
        -- Jika prompt yang muncul bukan trade (misal prompt beli item/error), biarkan fungsi asli berjalan normal
        return oldFirePrompt(self, promptText, ...)
    end
end)

if success then
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "System Ready";
        Text = "Bypass Controller Aktif! Trade akan di-accept otomatis.";
        Duration = 5;
    })
    print("🔴 AUTO ACCEPT TRADE HOOK: AKTIF")
else
    warn("❌ Gagal melakukan Hook pada PromptController: " .. tostring(err))
end
