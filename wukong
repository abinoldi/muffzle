-- // FUNGSI KLIK GAIB (ANTI-DETEKSI MOUSE) //
local function stealthClick(button)
    local success = false
    
    -- Memastikan executor mensupport getconnections
    if type(getconnections) == "function" then
        -- Mencari sinyal 'Activated' (paling umum di Roblox UI modern)
        for _, connection in pairs(getconnections(button.Activated)) do
            connection:Fire()
            success = true
        end
        
        -- Mencari sinyal 'MouseButton1Click' (untuk UI lama)
        for _, connection in pairs(getconnections(button.MouseButton1Click)) do
            connection:Fire()
            success = true
        end
        
        if success then
            print("🤫 [STEALTH] Tombol berhasil dipicu tanpa menggerakkan mouse!")
            return true
        end
    end
    
    warn("⚠️ Gagal melakukan stealth click. Executor mungkin tidak mendukung getconnections.")
    return false
end

-- // FUNGSI VALIDASI TRADE //
local function isTradeRequest(button)
    local current = button.Parent
    local maxIterations = 10
    local iterations = 0
    while current and iterations < maxIterations do
        local label = current:FindFirstChild("Label") or current:FindFirstChild("TextLabel")
        if label and label:IsA("TextLabel") then
            local text = label.Text:lower()
            if text:find("from") or text:find("give") or text:find("trade") then
                return true
            else
                return false
            end
        end
        current = current.Parent
        iterations = iterations + 1
    end
    return true
end

