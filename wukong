-- // KONFIGURASI //
local TARGET_GUI = "Prompt"
local TARGET_BUTTON = "Yes"
local TWEEN_SPEED = 150 -- Kecepatan terbang (studs/detik). Kurangi jika game mendeteksi speedhack.

-- // DATA LOKASI (UPDATED) //
local locations = {
    ["Treasure Room"] = {
        Pos = Vector3.new(-3561.297, -279.074, -1606.289), 
        Look = Vector3.new(-0.782, -0.000, -0.623)
    }
}

-- // SERVICES //
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

print("--- 🤖 AUTO-ACCEPT & SAFE TELEPORT LOADED ---")
print("📊 Koordinat: Treasure Room (Updated)")

-- // FUNGSI TELEPORT AMAN DENGAN TWEENSERVICE //
task.spawn(function()
    task.wait(2) -- Beri waktu agar karakter load sepenuhnya
    
    local locData = locations["Treasure Room"]
    local myChar = LocalPlayer.Character
    
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
        local hrp = myChar.HumanoidRootPart
        local targetCFrame = CFrame.lookAt(locData.Pos, locData.Pos + locData.Look)
        
        -- Hitung jarak dan waktu tempuh berdasarkan kecepatan
        local distance = (hrp.Position - locData.Pos).Magnitude
        local timeToTravel = distance / TWEEN_SPEED
        
        print("🚀 Memulai penerbangan (Tween) ke Treasure Room...")
        print("⏱️ Estimasi waktu tempuh: " .. string.format("%.2f", timeToTravel) .. " detik.")
        
        -- Matikan gravitasi sementara agar tidak jatuh saat proses Tween
        local bv = Instance.new("BodyVelocity")
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Parent = hrp
        
        -- Setup Tween
        local tweenInfo = TweenInfo.new(timeToTravel, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
        
        tween:Play()
        
        -- Tunggu sampai penerbangan selesai
        tween.Completed:Wait()
        
        -- Hapus anti-gravitasi setelah sampai
        bv:Destroy()
        print("📍 [AMAN] Berhasil tiba di Treasure Room!")
    else
        warn("⚠️ Gagal Teleport: Karakter belum siap.")
    end
end)

-- // FUNGSI UNTUK MENDAPATKAN POSISI BUTTON //
local function getButtonRect(button)
    if not (button and button.Visible and button.AbsoluteSize.Magnitude > 0) then return nil end
    local absPos = button.AbsolutePosition
    local absSize = button.AbsoluteSize
    local guiInset = GuiService:GetGuiInset()
    return { X = absPos.X, Y = absPos.Y + guiInset.Y, W = absSize.X, H = absSize.Y }
end

-- // FUNGSI KLIK SIMULASI (PALING AMAN) //
local function clickXY(x, y)
    VirtualInputManager:SendMouseMoveEvent(x, y, game)
    task.wait(0.02)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.02)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    print("🖱️ Clicked at:", x, y)
end

-- // FUNGSI VALIDASI TRADE //
local function isTradeRequest(button)
    local current = button.Parent
    local maxIterations = 10
    local iterations = 0
    while current and iterations < maxIterations do
        local label = current:FindFirstChild("Label") or current:FindFirstChild("TextLabel")
        if label and label:IsA("TextLabel") then
            local text = label.Text:lower()
            if text:find("from") or text:find("give") or text:find("trade") then
                return true
            else
                return false
            end
        end
        current = current.Parent
        iterations = iterations + 1
    end
    return true
end

-- // MAIN LOOP SCANNER (AUTO ACCEPT) //
task.spawn(function()
    while true do
        pcall(function()
            local prompt = PlayerGui:FindFirstChild(TARGET_GUI)
            if prompt and prompt.Enabled then
                for _, obj in ipairs(prompt:GetDescendants()) do
                    if obj.Name == TARGET_BUTTON and obj:IsA("ImageButton") and obj.Visible then
                        if isTradeRequest(obj) then
                            local rect = getButtonRect(obj)
                            if rect then
                                local centerX = rect.X + (rect.W / 2)
                                local centerY = rect.Y + (rect.H / 2)
                                
                                warn("✅ TRADE DETECTED! Clicking Yes button...")
                                clickXY(centerX, centerY)
                                
                                -- Random delay 1.0 - 1.5 detik
                                local randomClickDelay = math.random(10, 15) / 10 
                                print("⏳ Menunggu " .. randomClickDelay .. " detik...")
                                task.wait(randomClickDelay)
                            end
                        end
                    end
                end
            end
        end)
        task.wait(0.5)
    end
end)

