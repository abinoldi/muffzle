-- // KONFIGURASI //
local TARGET_GUI = "Prompt"
local TARGET_BUTTON = "Yes"
local CLICKS_PER_SECOND = 1
local TP_INTERVAL = 5 -- Detik jeda antar teleport
local MAX_TELEPORTS = 2 -- Maksimal 3x teleport

-- // SERVICES //
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

print("--- 🤖 AUTO-ACCEPT & TELEPORT LOADED (CLICK METHOD) ---")
print("📊 Konfigurasi: Teleport " .. MAX_TELEPORTS .. "x | Click " .. CLICKS_PER_SECOND .. "/detik")

-- // FUNGSI UNTUK MENDAPATKAN TARGET PLAYER TERDEKAT //
local function getTargetPlayer()
    local allPlayers = Players:GetPlayers()
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
    
    local myPos = myChar.HumanoidRootPart.Position
    local closestPlayer = nil
    local closestDistance = math.huge
    
    for _, plr in ipairs(allPlayers) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local theirPos = plr.Character.HumanoidRootPart.Position
            local distance = (myPos - theirPos).Magnitude
            
            if distance < closestDistance then
                closestDistance = distance
                closestPlayer = plr
            end
        end
    end
    return closestPlayer
end

-- // FUNGSI TELEPORT (HANYA 3 KALI) //
task.spawn(function()
    local teleportCount = 0
    
    while teleportCount < MAX_TELEPORTS do
        local target = getTargetPlayer()
        if target and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local targetHRP = target.Character.HumanoidRootPart
            local myHRP = LocalPlayer.Character.HumanoidRootPart
            
            -- Teleport ke posisi player (sedikit di depan mereka)
            myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, -3)
            
            teleportCount = teleportCount + 1
            print("📍 Teleport ke-" .. teleportCount .. " ke player:", target.Name)
            
            if teleportCount < MAX_TELEPORTS then
                task.wait(TP_INTERVAL)
            end
        else
            print("⚠️ Tidak ada target player untuk teleport ke-" .. (teleportCount + 1))
            task.wait(TP_INTERVAL)
        end
    end
    
    print("✅ Teleport selesai (" .. MAX_TELEPORTS .. "x teleport telah dilakukan)")
end)

-- // FUNGSI UNTUK MENDAPATKAN POSISI BUTTON //
local function getButtonRect(button)
    if not (button and button.Visible and button.AbsoluteSize.Magnitude > 0) then return nil end
    
    local absPos = button.AbsolutePosition
    local absSize = button.AbsoluteSize
    local guiInset = GuiService:GetGuiInset()
    
    return {
        X = absPos.X,
        Y = absPos.Y + guiInset.Y,
        W = absSize.X,
        H = absSize.Y
    }
end

-- // FUNGSI KLIK SIMULASI //
local function clickXY(x, y)
    -- Simulasi input mouse asli
    VirtualInputManager:SendMouseMoveEvent(x, y, game)
    task.wait(0.02)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.02)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    print("🖱️ Clicked at:", x, y)
end

-- // FUNGSI UNTUK CEK APAKAH INI TRADE REQUEST ATAU JUAL BELI //
local function isTradeRequest(button)
    -- Cari parent frame yang berisi label
    local current = button.Parent
    local maxIterations = 10
    local iterations = 0
    
    while current and iterations < maxIterations do
        -- Cari label di dalam current
        local label = current:FindFirstChild("Label") or current:FindFirstChild("TextLabel")
        if label and label:IsA("TextLabel") then
            local text = label.Text:lower()
            -- Cek apakah ini trade request (bukan jual/beli)
            if text:find("from") or text:find("give") or text:find("trade") then
                return true
            else
                return false -- Ini kemungkinan jual/beli
            end
        end
        current = current.Parent
        iterations = iterations + 1
    end
    
    -- Default: anggap trade request jika tidak menemukan label
    return true
end

-- // MAIN LOOP SCANNER (CLICK 1 KALI PER DETIK) //
task.spawn(function()
    local clickDelay = 1 / CLICKS_PER_SECOND -- = 1 detik karena CLICKS_PER_SECOND = 1
    
    while true do
        pcall(function()
            local prompt = PlayerGui:FindFirstChild(TARGET_GUI)
            
            -- Cek apakah Prompt GUI aktif
            if prompt and prompt.Enabled then
                print("🔍 Scanning Prompt GUI...")
                
                for _, obj in ipairs(prompt:GetDescendants()) do
                    if obj.Name == TARGET_BUTTON and obj:IsA("ImageButton") and obj.Visible then
                        
                        -- Validasi apakah ini benar trade request
                        if isTradeRequest(obj) then
                            local rect = getButtonRect(obj)
                            if rect then
                                local centerX = rect.X + (rect.W / 2)
                                local centerY = rect.Y + (rect.H / 2)
                                
                                warn("✅ TRADE DETECTED! Clicking Yes button...")
                                clickXY(centerX, centerY)
                                
                                task.wait(clickDelay) -- Jeda 1 detik antar klik
                            end
                        else
                            print("⏭️ Skipping - This appears to be a buy/sell prompt")
                        end
                    end
                end
            end
        end)
        task.wait(0.5) -- Scan setiap 0.5 detik
    end
end)

