-- // FUNGSI UNTUK MENDAPATKAN POSISI BUTTON //
local function getButtonRect(button)
    if not (button and button.Visible and button.AbsoluteSize.Magnitude > 0) then return nil end
    local absPos = button.AbsolutePosition
    local absSize = button.AbsoluteSize
    local guiInset = GuiService:GetGuiInset()
    return { X = absPos.X, Y = absPos.Y + guiInset.Y, W = absSize.X, H = absSize.Y }
end

-- // FUNGSI KLIK HUMANIZED (AMAN DARI DETEKSI PIKSEL) //
local function humanizedClick(rect)
    -- Pastikan area tombol cukup besar untuk dirandom. Jika terlalu kecil, gunakan titik tengah biasa.
    if rect.W < 10 or rect.H < 10 then return end
    
    -- Mengacak koordinat X dan Y di dalam tombol (diberi margin agar tidak klik di pinggir/border luar)
    local randomX = rect.X + math.random(5, rect.W - 5)
    local randomY = rect.Y + math.random(5, rect.H - 5)
    
    -- Menggerakkan mouse ke titik acak tersebut
    VirtualInputManager:SendMouseMoveEvent(randomX, randomY, game)
    
    -- Jeda acak 0.03 - 0.08 detik sebelum menekan (seperti delay reaksi manusia)
    task.wait(math.random(3, 8) / 100) 
    VirtualInputManager:SendMouseButtonEvent(randomX, randomY, 0, true, game, 0)
    
    -- Jeda acak 0.02 - 0.05 detik (seperti variasi lamanya manusia menahan klik kiri mouse)
    task.wait(math.random(2, 5) / 100) 
    VirtualInputManager:SendMouseButtonEvent(randomX, randomY, 0, false, game, 0)
    
    print("🖱️ [HUMAN CLICK] Titik:", randomX, randomY)
end

-- // FUNGSI VALIDASI TRADE //
local function isTradeRequest(button)
    local current = button.Parent
    local maxIterations = 10
    local iterations = 0
    while current and iterations < maxIterations do
        local label = current:FindFirstChild("Label") or current:FindFirstChild("TextLabel")
        if label and label:IsA("TextLabel") then
            local text = label.Text:lower()
            if text:find("from") or text:find("give") or text:find("trade") then
                return true
            else
                return false
            end
        end
        current = current.Parent
        iterations = iterations + 1
    end
    return true
end

-- // MAIN LOOP SCANNER (AUTO ACCEPT) //
task.spawn(function()
    while true do
        pcall(function()
            local prompt = PlayerGui:FindFirstChild(TARGET_GUI)
            if prompt and prompt.Enabled then
                for _, obj in ipairs(prompt:GetDescendants()) do
                    if obj.Name == TARGET_BUTTON and obj:IsA("ImageButton") and obj.Visible then
                        if isTradeRequest(obj) then
                            local rect = getButtonRect(obj)
