                                warn("✅ TRADE DETECTED! Clicking Yes button dynamically...")
                                
                                -- Panggil fungsi klik yang sudah diacak koordinatnya
                                humanizedClick(rect)
                                
                                -- Random delay untuk jeda trade berikutnya (1.0 - 1.5 detik)
                                local randomTradeDelay = math.random(10, 15) / 10 
                                print("⏳ Menunggu " .. randomTradeDelay .. " detik...")
                                task.wait(randomTradeDelay)
                            end
                        end
                    end
                end
            end
        end)
        task.wait(0.5)
    end
end)

