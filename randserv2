const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));
const ask = (q) => new Promise(r => {
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  rl.question(q, (ans) => { rl.close(); r(ans); });
});

function getPackages() {
  try {
    return execSync("pm list packages | grep roblox", { encoding: "utf8" })
      .split("\n").filter(l => l.trim()).map(l => l.replace("package:", "").trim());
  } catch { return []; }
}

function getRobloxCookie(packageName) {
  try {
    const cookiesPath = `/data/data/${packageName}/app_webview/Default/Cookies`;
    const tempPath = `/sdcard/temp_cookie_${packageName}_${Date.now()}.db`;
    execSync(`cp "${cookiesPath}" "${tempPath}"`);
    const sqliteCmd = fs.existsSync(SQLITE_PATH) ? SQLITE_PATH : "sqlite3";
    const query = `${sqliteCmd} "${tempPath}" "SELECT value FROM cookies WHERE name = '.ROBLOSECURITY' LIMIT 1"`;
    let cookie = execSync(query).toString().trim();
    execSync(`rm "${tempPath}"`);
    if (cookie && !cookie.startsWith("_")) cookie = "_" + cookie;
    return cookie ? `.ROBLOSECURITY=${cookie}` : null;
  } catch { return null; }
}

async function getUserInfo(cookie) {
  if (!cookie) return { id: null, name: "No Cookie" };
  try {
    const res = await axios.get("https://users.roblox.com/v1/users/authenticated", {
      headers: { Cookie: cookie, "User-Agent": "Mozilla/5.0 (Android 10; Mobile)" }
    });
    return { id: res.data.id, name: res.data.name };
  } catch { 
    return { id: null, name: "Expired" };
  }
}

function stopPackage(pkg) {
  try { execSync(`am force-stop ${pkg}`, { stdio: 'ignore' }); } catch (e) {} 
}

function releaseMemory() {
  try {
    execSync('su -c "sync; echo 3 > /proc/sys/vm/drop_caches"', { stdio: 'ignore' });
    return true;
  } catch (e) { return false; }
}

function getAppRam(pkg) {
  try {
    const pid = execSync(`su -c "pidof ${pkg}"`, { encoding: 'utf8' }).trim();
    if (!pid) return "0 MB";
    const memInfo = execSync(`su -c "dumpsys meminfo ${pkg} | grep -E 'TOTAL:|TOTAL PSS:'"`, { encoding: 'utf8' }).trim();
    const match = memInfo.match(/\d+/);
    if (match) {
        const mb = (parseInt(match[0]) / 1024).toFixed(1);
        return `${mb} MB`;
    }
    return "N/A";
  } catch (e) {
    return "0 MB";
  }
}

// --- FUNCTION TO CHECK IF USER IS IN-GAME (BASED ON PRESENCE) - FIXED VERSION ---
function isUserInGame(pkg) {
  try {
    // Check if app is running
    const pid = execSync(`su -c "pidof ${pkg}"`, { encoding: 'utf8' }).trim();
    if (!pid) {
      if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: No PID found`);
      return false; // App tidak berjalan
    }
    
    // METHOD 1: Cek foreground app (paling akurat)
    try {
      const foregroundApp = execSync(`su -c "dumpsys window windows | grep -E 'mCurrentFocus|mFocusedApp' | head -1"`, { encoding: 'utf8' }).trim();
      
      if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: Foreground: ${foregroundApp}`);
      
      // Jika package name ada di foreground app, berarti sedang aktif
      if (foregroundApp.includes(pkg)) {
        return true; // Benar-benar di foreground = in game
      }
      
      // Cek juga apakah ada aktivitas Roblox yang terlihat
      if (foregroundApp.includes("Roblox") || foregroundApp.includes("roblox")) {
        return true;
      }
    } catch (e) {}
    
    // METHOD 2: Cek activity stack untuk melihat apakah ada activity yang visible
    try {
      const activityStack = execSync(`su -c "dumpsys activity activities | grep -A 5 '${pkg}' | grep -E 'mVisible=true|ResumedActivity|top-activity'"`, { encoding: 'utf8' }).trim();
      
      if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: Activity visible: ${activityStack.substring(0, 100)}`);
      
      if (activityStack.includes("mVisible=true") || 
          activityStack.includes("ResumedActivity")) {
        return true; // Activity visible = in game
      }
    } catch (e) {}
    
    // METHOD 3: Cek process importance
    try {
      const procInfo = execSync(`su -c "dumpsys activity processes | grep -A 10 '${pkg}' | grep -E 'importance=|procState='"`, { encoding: 'utf8' }).trim();
      
      if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: Process info: ${procInfo}`);
      
      // Importance: 100 = foreground, 200 = visible, >200 = background
      if (procInfo.includes("importance=100") || procInfo.includes("importance=200") ||
          procInfo.includes("procState=TOP") || procInfo.includes("procState=IMPORTANT_VISIBLE")) {
        return true; // Foreground or visible
      }
      
      // Jika importance > 200, berarti di background
      if (procInfo.includes("importance=")) {
        const match = procInfo.match(/importance=(\d+)/);
        if (match && parseInt(match[1]) > 200) {
          return false; // Background, not in game
        }
      }
    } catch (e) {}
    
    // METHOD 4: Cek app state via appops
    try {
      const appState = execSync(`su -c "dumpsys appops get ${pkg} | grep -i 'state' | head -1"`, { encoding: 'utf8' }).trim();
      
      if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: App state: ${appState}`);
      
      if (appState.includes("FOREGROUND") || appState.includes("TOP") || appState.includes("FOCUSED")) {
        return true;
      }
    } catch (e) {}
    
    // METHOD 5: Cek apakah ada window yang terlihat
    try {
      const windows = execSync(`su -c "dumpsys window windows | grep -E 'Window.*${pkg}' | grep -v 'mSurface='"`, { encoding: 'utf8' }).trim();
      
      if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: Windows: ${windows.substring(0, 100)}`);
      
      if (windows.includes(pkg)) {
        return true; // Ada window dari package ini
      }
    } catch (e) {}
    
    // Jika semua method gagal, cek apakah proses ini penting (bukan cached)
    try {
      const oomScore = execSync(`su -c "cat /proc/${pid}/oom_score"`, { encoding: 'utf8' }).trim();
      const oomScoreAdj = execSync(`su -c "cat /proc/${pid}/oom_score_adj"`, { encoding: 'utf8' }).trim();
      
      if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: oom_score=${oomScore}, oom_score_adj=${oomScoreAdj}`);
      
      // Foreground app biasanya oom_score_adj = -900 sampai 0
      if (parseInt(oomScoreAdj) <= 0) {
        return true; // Kemungkinan foreground
      }
      
      // Cached processes usually have high oom_score
      if (parseInt(oomScore) > 300) {
        return false; // Kemungkinan cached/background
      }
    } catch (e) {}
    
    // Jika masih belum bisa menentukan, cek apakah app visible dengan cara sederhana
    try {
      // Coba lihat apakah ada activity dari package ini di stack
      const stackCheck = execSync(`su -c "dumpsys activity activities | grep -i '${pkg}' | head -5"`, { encoding: 'utf8' }).trim();
      
      if (stackCheck.length > 0) {
        // Ada activity, kemungkinan sedang berjalan
        return true;
      }
    } catch (e) {}
    
    // Default: jika ragu dan app masih running, anggap in game (prevent false positive rejoin)
    if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: No clear detection, assuming in game based on running process`);
    return true;
    
  } catch (e) {
    if (DEBUG_MODE) console.log(`[DEBUG] ${pkg}: Error in isUserInGame: ${e.message}`);
    // Jika error total, asumsikan tidak dalam game (lebih agresif untuk rejoin)
    return false;
  }
}

// --- FUNCTION TO CHECK IF APP IS HEALTHY (RAM > THRESHOLD AND USER IN GAME) ---
function isAppHealthy(pkg) {
  // Check 1: Apakah proses berjalan?
  const processRunning = isAppRunning(pkg);
  if (!processRunning) {
    return { healthy: false, reason: "Process Not Running", ram: 0 };
  }
  
  // Check 2: Cek RAM usage
  const ramStr = getAppRam(pkg);
  const ramValue = parseFloat(ramStr) || 0;
  const ramBelowThreshold = ramValue < MIN_RAM_THRESHOLD;
  
  // Check 3: Cek Presence (sekarang lebih akurat)
  const userInGame = isUserInGame(pkg);
  
  // Debug output jika diperlukan
  if (DEBUG_MODE) {
    console.log(`[DEBUG] ${pkg}: RAM=${ramValue}MB, Threshold=${MIN_RAM_THRESHOLD}MB, InGame=${userInGame}`);
  }
  
  // Logika: Jika RAM di bawah threshold ATAU user tidak dalam game, maka tidak sehat
  if (ramBelowThreshold) {
    return { healthy: false, reason: `Low RAM (${ramValue}MB < ${MIN_RAM_THRESHOLD}MB)`, ram: ramValue };
  }
  
  if (!userInGame) {
    return { healthy: false, reason: "User Not In Game", ram: ramValue };
  }
  
  // Semua check lulus
  return { healthy: true, reason: "Healthy", ram: ramValue };
}

function autoArrangeXML(packages) {
  console.log(`\n📐 Mengatur XML (Grid ${GRID_COLS}xN | Size ${BOX_SIZE} | Gap Y ${GAP_Y})...`);
  packages.sort();
  packages.forEach((pkg, index) => {
    const col = index % GRID_COLS;
    const row = Math.floor(index / GRID_COLS);

    const left = col * (BOX_SIZE + GAP_X);
    const top = (row * (BOX_SIZE + GAP_Y)) + START_OFFSET_Y;
    const right = left + BOX_SIZE;
    const bottom = top + BOX_SIZE;

    const prefsFile = `/data/data/${pkg}/shared_prefs/${pkg}_preferences.xml`;

    const cmd = `su -c "
      sed -i 's|app_cloner_current_window_left\\" value=\\"[0-9]*|app_cloner_current_window_left\\" value=\\"${left}|' ${prefsFile};
      sed -i 's|app_cloner_current_window_top\\" value=\\"[0-9]*|app_cloner_current_window_top\\" value=\\"${top}|' ${prefsFile};
      sed -i 's|app_cloner_current_window_right\\" value=\\"[0-9]*|app_cloner_current_window_right\\" value=\\"${right}|' ${prefsFile};
      sed -i 's|app_cloner_current_window_bottom\\" value=\\"[0-9]*|app_cloner_current_window_bottom\\" value=\\"${bottom}|' ${prefsFile};
      sed -i 's|<int name=\\"GraphicsQualityLevel\\" value=\\".*\\" />|<int name=\\"GraphicsQualityLevel\\" value=\\"1\\" />|g' ${prefsFile};
      chmod 660 ${prefsFile}
    "`;
    try { execSync(cmd, { stdio: 'ignore' }); } catch (e) {}
  });
  console.log("✅ Posisi XML tersimpan dan Grafis dipaksa rata kiri.");
}

async function launchPackage(pkg, url) {
  try {
    const cmd = `am start -n ${pkg}/com.roblox.client.ActivityProtocolLaunch -f 0x18080000 -a android.intent.action.VIEW -d "${url}"`;
    execSync(cmd, { stdio: 'ignore' });
  } catch (e) {}
}

async function protectProcessFromLMK(pkg) {
  try {
    const pid = execSync(`su -c "pidof ${pkg}"`, { encoding: 'utf8' }).trim();
    if (pid) {
      execSync(`su -c "echo -900 > /proc/${pid}/oom_score_adj"`, { stdio: 'ignore' });
      return true;
    }
  } catch (e) {
    return false;
  }
}

